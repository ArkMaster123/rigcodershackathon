{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "workspace",
    "scripts": {
        "fmt": "biome format --write",
        "docs": "typedoc",
        "docs:merge": "typedoc --entryPointStrategy merge packages/*/docs.json",
        "gen": "turbo gen",
        "typos": "typos",
        "ast-grep": "ast-grep scan",
        "ast-grep:apply": "ast-grep scan -U",
        "db:sync": "./scripts/sync-db.sh"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.2.0",
        "@swc-node/register": "^1.10.9",
        "@turbo/gen": "^2.1.1",
        "@types/bun": "^1.2.17",
        "@vercel/postgres": "^0.9.0",
        "drizzle-orm": "^0.41.0",
        "pg": "^8.12.0",
        "postgres": "^3.4.4",
        "source-map-support": "^0.5.21",
        "ts-node": "^10.9.2",
        "turbo": "^2.5.4",
        "typedoc": "^0.26.6",
        "typedoc-plugin-mdn-links": "^3.2.11",
        "typedoc-plugin-mermaid": "^1.12.0",
        "typedoc-plugin-zod": "^1.2.1",
        "typescript": "^5.8.2"
    },
    "packageManager": "pnpm@9.12.0",
    "engines": {
        "node": "24.11.1",
        "pnpm": "9"
    }
}